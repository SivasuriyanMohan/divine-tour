<div class="temple-testimonials-wrapper">
  <div class="temple-testimonials-slider">
    {% for item in items %}
      <div class="testimonial-item">
        <p class="testimonial-comment">{{ item.comment }}</p>
        <div class="testimonial-meta">
          <span class="testimonial-author">- {{ item.author }}</span>
          <span class="testimonial-temple">{{ item.title }}</span>
        </div>
      </div>
    {% endfor %}
  </div>
</div>